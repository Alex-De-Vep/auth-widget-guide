{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"strict": true,
		"types": ["node"]
	},
	"include": ["vite.config.ts", "playwright.config.ts", "e2e/**/*.ts"]
}
